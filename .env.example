# Optional — only needed to enable the LIVE AI tutor on a deployed site.
# Point this at your hosted tutor-server.cjs backend (Render/Railway/Azure/etc.).
# Leave it unset for local dev (defaults to http://localhost:5189) or to run
# the deployed app in offline-tutor mode.
#
# Copy this file to .env and set the value, then rebuild (npm run build).
VITE_TUTOR_URL=https://your-tutor-backend.example.com
